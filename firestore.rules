rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'eaffumgyan@gmail.com' ||
        (exists(/databases/$(database)/documents/appData/main) &&
         request.auth.token.email in get(/databases/$(database)/documents/appData/main).data.adminEmails)
      );
    }

    match /appData/{docId} {
      allow read: if isAdmin() || (isSignedIn() && docId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && docId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && docId == request.auth.uid);
    }
  }
}
